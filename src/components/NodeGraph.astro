---
// NodeGraph.astro - Animated payment network visualization
// Two primary gateway nodes with clustered subgraphs on each side
// Single bridge between primary nodes
---

<div class="bg-nodes">
	<svg class="node-graph" viewBox="0 0 1200 800" fill="none">
		<defs>
			<filter id="glow-particle" x="-100%" y="-100%" width="300%" height="300%">
				<feGaussianBlur stdDeviation="3" result="blur"/>
				<feMerge>
					<feMergeNode in="blur"/>
					<feMergeNode in="SourceGraphic"/>
				</feMerge>
			</filter>
			
			<filter id="node-glow" x="-50%" y="-50%" width="200%" height="200%">
				<feGaussianBlur stdDeviation="2" result="blur"/>
				<feMerge>
					<feMergeNode in="blur"/>
					<feMergeNode in="SourceGraphic"/>
				</feMerge>
			</filter>
		</defs>

		<!-- === SINGLE BRIDGE BETWEEN PRIMARY NODES === -->
		<path d="M 400 360 L 800 440" stroke="#2a2a3a" stroke-width="2" opacity="1"/>

		<!-- === LEFT SUBGRAPH (gateway: primary node 1 at 400,360) === -->
		<!-- Primary to secondary nodes -->
		<line x1="400" y1="360" x2="260" y2="200" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="400" y1="360" x2="180" y2="340" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="400" y1="360" x2="320" y2="520" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="400" y1="360" x2="500" y2="280" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="400" y1="360" x2="280" y2="440" stroke="#252535" stroke-width="2" opacity="1"/>

		<!-- Left cluster interconnections -->
		<line x1="260" y1="200" x2="180" y2="340" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="260" y1="200" x2="280" y2="440" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="180" y1="340" x2="280" y2="440" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="320" y1="520" x2="280" y2="440" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="320" y1="520" x2="500" y2="280" stroke="#1a1a25" stroke-width="2" opacity="1"/>

		<!-- Left secondary nodes -->
		<circle cx="260" cy="200" r="8" fill="#2a2a3a"/>
		<circle cx="180" cy="340" r="7" fill="#2a2a3a"/>
		<circle cx="320" cy="520" r="8" fill="#2a2a3a"/>
		<circle cx="500" cy="280" r="6" fill="#2a2a3a"/>
		<circle cx="280" cy="440" r="7" fill="#2a2a3a"/>
		<circle cx="380" cy="180" r="5" fill="#252535"/>
		<circle cx="140" cy="420" r="5" fill="#252535"/>

		<!-- Left cluster connections to outer nodes -->
		<line x1="260" y1="200" x2="380" y2="180" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="180" y1="340" x2="140" y2="420" stroke="#1a1a25" stroke-width="2" opacity="1"/>

		<!-- === RIGHT SUBGRAPH (gateway: primary node 2 at 800,440) === -->
		<!-- Primary to secondary nodes -->
		<line x1="800" y1="440" x2="940" y2="280" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="800" y1="440" x2="1020" y2="360" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="800" y1="440" x2="880" y2="600" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="800" y1="440" x2="700" y2="320" stroke="#252535" stroke-width="2" opacity="1"/>
		<line x1="800" y1="440" x2="920" y2="520" stroke="#252535" stroke-width="2" opacity="1"/>

		<!-- Right cluster interconnections -->
		<line x1="940" y1="280" x2="1020" y2="360" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="940" y1="280" x2="920" y2="520" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="1020" y1="360" x2="920" y2="520" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="880" y1="600" x2="920" y2="520" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="880" y1="600" x2="700" y2="320" stroke="#1a1a25" stroke-width="2" opacity="1"/>

		<!-- Right secondary nodes -->
		<circle cx="940" cy="280" r="8" fill="#2a2a3a"/>
		<circle cx="1020" cy="360" r="7" fill="#2a2a3a"/>
		<circle cx="880" cy="600" r="8" fill="#2a2a3a"/>
		<circle cx="700" cy="320" r="6" fill="#2a2a3a"/>
		<circle cx="920" cy="520" r="7" fill="#2a2a3a"/>
		<circle cx="820" cy="200" r="5" fill="#252535"/>
		<circle cx="1060" cy="620" r="5" fill="#252535"/>

		<!-- Right cluster connections to outer nodes -->
		<line x1="940" y1="280" x2="820" y2="200" stroke="#1a1a25" stroke-width="2" opacity="1"/>
		<line x1="880" y1="600" x2="1060" y2="620" stroke="#1a1a25" stroke-width="2" opacity="1"/>

		<!-- === PRIMARY NODES (gateways) === -->
		<circle cx="400" cy="360" r="14" fill="#3a3a4a" filter="url(#node-glow)"/>
		<circle cx="800" cy="440" r="14" fill="#3a3a4a" filter="url(#node-glow)"/>

		<!-- === MOVING PARTICLES === -->
		<!-- Bridge particle (between hubs) -->
		<circle r="5" fill="#00ff88" filter="url(#glow-particle)" class="particle particle-1"/>

		<!-- Left subgraph particles -->
		<circle r="4" fill="#00d4ff" filter="url(#glow-particle)" class="particle particle-2"/>
		<circle r="3" fill="#a855f7" filter="url(#glow-particle)" class="particle particle-3"/>
		<circle r="4" fill="#00ff88" filter="url(#glow-particle)" class="particle particle-4"/>
		<circle r="3" fill="#00d4ff" filter="url(#glow-particle)" class="particle particle-5"/>

		<!-- Right subgraph particles -->
		<circle r="4" fill="#00d4ff" filter="url(#glow-particle)" class="particle particle-6"/>
		<circle r="3" fill="#a855f7" filter="url(#glow-particle)" class="particle particle-7"/>
		<circle r="4" fill="#00ff88" filter="url(#glow-particle)" class="particle particle-8"/>
		}