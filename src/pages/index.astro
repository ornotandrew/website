<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Andrew van Rooyen — Software Engineer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600&display=swap" rel="stylesheet">
  <style>
    :root { --bg: #0a0a12; --text: #e8e8ed; --muted: #6b6b7a; --accent: #00ff88; }
    body { font-family: 'Space Grotesk', sans-serif; background: var(--bg); color: var(--text); margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    main { padding: 2rem; max-width: 600px; width: 100%; }
    .kicker { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted); margin-bottom: 0.75rem; }
    .pulse { color: var(--accent); animation: p 2s infinite; }
    @keyframes p { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    h1 { font-size: clamp(2.5rem, 8vw, 4.5rem); margin: 0 0 0.75rem; line-height: 1.05; letter-spacing: -0.03em; background: linear-gradient(135deg, #fff, #c8f0ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .last-name { font-size: 0.75em; }
    .tagline { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted); margin-bottom: 0.75rem; }
    .hero-links { display: grid; grid-template-columns: auto auto; gap: 0.5rem 2rem; margin-top: 1.5rem; }
    .social-links, .nav-links { display: flex; flex-direction: column; gap: 0.25rem; }
    a { color: var(--muted); text-decoration: none; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; transition: color 0.2s; }
    a:hover { color: var(--text); }
    footer { padding: 1rem 0; }
    footer span { font-size: 0.75rem; color: var(--muted); opacity: 0.5; }
    .bg-nodes { position: fixed; top: 0; right: -10%; width: 80vw; height: 100vh; opacity: 0.6; z-index: 0; }
    .particle { offset-rotate: 0deg; animation: flow linear infinite; }
    .particle-1 { offset-path: path('M400 320 L 800 480'); animation-duration: 4s; }
    @keyframes flow { 0% { offset-distance: 0%; opacity: 0; } 10% { opacity: 1; } 90% { opacity: 1; } 100% { offset-distance: 100%; opacity: 0; } }
  </style>
</head>
<body>
  <div class="bg-nodes">
    <svg viewBox="0 0 1200 800" fill="none">
      <line x1="400" y1="320" x2="800" y2="480" stroke="#3a3a4a" stroke-width="2" opacity="0.7"/>
      <line x1="400" y1="320" x2="280" y2="180" stroke="#3a3a4a" stroke-width="1" opacity="0.7"/>
      <line x1="400" y1="320" x2="350" y2="550" stroke="#3a3a4a" stroke-width="1" opacity="0.7"/>
      <line x1="800" y1="480" x2="920" y2="320" stroke="#3a3a4a" stroke-width="1" opacity="0.7"/>
      <line x1="800" y1="480" x2="850" y2="680" stroke="#3a3a4a" stroke-width="1" opacity="0.7"/>
      <circle cx="400" cy="320" r="16" fill="#3a3a4a"/>
      <circle cx="800" cy="480" r="16" fill="#3a3a4a"/>
      <circle cx="280" cy="180" r="10" fill="#3a3a4a"/>
      <circle cx="350" cy="550" r="10" fill="#3a3a4a"/>
      <circle cx="920" cy="320" r="10" fill="#3a3a4a"/>
      <circle cx="850" cy="680" r="10" fill="#3a3a4a"/>
      <circle r="8" fill="#00ff88" class="particle particle-1"/>
    </svg>
  </div>
  <main>
    <div class="kicker"><span class="pulse">●</span> Cape Town, South Africa</div>
    <h1>Andrew<br/><span class="last-name">van Rooyen</span></h1>
    <p class="tagline">Engineering / Fintech</p>
    <div class="hero-links">
      <div class="social-links">
        <a href="https://www.linkedin.com/in/andrewvanrooyen/">LinkedIn</a>
        <a href="mailto:andrew@andrewvr.dev">Email</a>
        <a href="https://github.com/ornotandrew">GitHub</a>
      </div>
      <div class="nav-links">
        <a href="https://andrewvr.dev/bookshelf">Bookshelf</a>
        <a href="/blog/">Blog</a>
      </div>
    </div>
    <footer><span>EOF</span></footer>
  </main>
</body>
</html>