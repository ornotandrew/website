---
import NodeGraph from '../components/NodeGraph.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Andrew van Rooyen — Software Engineer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;600&display=swap" rel="stylesheet">

  <style>
    :root { 
      --bg: #08080c; 
      --text: #e8e8ed;
      --muted: #6b6b7a;
      --accent: #00d4ff;
      --grid-color: rgba(90, 90, 110, 0.1);
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Background layers */
    .bg-layer {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    /* Engineering grid - subtle, technical */
    .grid-bg {
      background-image: 
        linear-gradient(var(--grid-color) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    /* Radial gradient - depth, not decoration */
    .gradient-bg {
      background: radial-gradient(
        ellipse 100% 80% at 50% 50%,
        rgba(12, 15, 25, 0.5) 0%,
        rgba(8, 8, 12, 0.2) 40%,
        transparent 70%
      );
    }

    /* Subtle vignette */
    .vignette {
      background: radial-gradient(
        ellipse 100% 100% at 50% 50%,
        transparent 50%,
        rgba(0, 0, 0, 0.5) 100%
      );
    }

    /* Main content */
    main {
      position: relative;
      z-index: 10;
      padding: 2rem;
      max-width: 600px;
      width: 100%;
    }

    .kicker { 
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem; 
      text-transform: uppercase; 
      letter-spacing: 0.2em; 
      color: var(--muted); 
      margin-bottom: 0.75rem;
    }

    .pulse { color: var(--accent); animation: p 2s infinite; }
    @keyframes p { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    h1 { 
      font-size: clamp(2.5rem, 8vw, 4.5rem); 
      margin: 0 0 0.75rem; 
      line-height: 1.05; 
      letter-spacing: -0.03em; 
      background: linear-gradient(135deg, #fff 0%, #c8f0ff 60%, #a8d4e6 100%); 
      -webkit-background-clip: text; 
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .last-name { 
      font-size: 0.75em;
      background: linear-gradient(135deg, #e8fdf4 0%, #c8fce8 100%); 
      -webkit-background-clip: text; 
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .tagline { 
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem; 
      text-transform: uppercase; 
      letter-spacing: 0.15em; 
      color: var(--muted); 
      margin-bottom: 1.5rem;
    }

    .hero-links { 
      display: grid; 
      grid-template-columns: auto auto; 
      gap: 0.5rem 3rem; 
      margin-top: 2rem; 
    }

    .social-links, .nav-links { 
      display: flex; 
      flex-direction: column; 
      gap: 0.75rem; 
    }

    a { 
      color: var(--muted); 
      text-decoration: none; 
      font-size: 0.9rem; 
      text-transform: uppercase; 
      letter-spacing: 0.12em;
      transition: color 0.2s;
      font-family: 'JetBrains Mono', monospace;
    }

    a:hover { color: var(--text); }

    footer { 
      margin-top: 3rem;
      padding-top: 1rem;
    }

    footer span { 
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem; 
      color: var(--muted); 
      opacity: 0.4; 
      letter-spacing: 0.1em;
    }
  </style>
</head>
<body>
  <!-- Background layers -->
  <div class="bg-layer grid-bg"></div>
  <div class="bg-layer gradient-bg"></div>
  <div class="bg-layer vignette"></div>

  <!-- Node graph -->
  <NodeGraph />

  <main>
    <div class="kicker"><span class="pulse">●</span> Cape Town, South Africa</div>
    <h1>Andrew<br/><span class="last-name">van Rooyen</span></h1>
    <p class="tagline">Engineering / Fintech</p>
    <div class="hero-links">
      <div class="social-links">
        <a href="https://www.linkedin.com/in/andrewvanrooyen/">LinkedIn</a>
        <a href="mailto:andrew@andrewvr.dev">Email</a>
        <a href="https://github.com/ornotandrew">GitHub</a>
      </div>
      <div class="nav-links">
        <a href="https://andrewvr.dev/bookshelf">Bookshelf</a>
        <a href="/blog/">Blog</a>
      </div>
    </div>
    <footer><span>EOF</span></footer>
  </main>
</body>
</html>
